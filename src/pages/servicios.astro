---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    num: '01',
    title: 'Branding e identidad',
    desc: 'Construimos marcas con criterio: una base sólida que se ve, suena y se siente coherente en cada punto de contacto.',
    deliverables: ['Naming', 'Logotipo', 'Sistema visual', 'Guía de marca', 'Tono de voz', 'Papelería'],
  },
  {
    num: '02',
    title: 'Diseño web / UX-UI',
    desc: 'Sitios y productos rápidos, claros y pensados para convertir visitas en clientes. Diseño y desarrollo en un mismo equipo.',
    deliverables: ['Diseño UX/UI', 'Webs a medida', 'Landing pages', 'Prototipado', 'Responsive', 'CMS'],
  },
  {
    num: '03',
    title: 'Marketing digital y campañas',
    desc: 'Estrategia, paid media y embudos que convierten. Medimos cada peso invertido para escalar lo que funciona.',
    deliverables: ['Estrategia', 'Paid media', 'Embudos', 'Email marketing', 'Contenido', 'Analítica'],
  },
  {
    num: '04',
    title: 'SEO / SEM',
    desc: 'Posicionamiento orgánico y de pago para que te encuentren cuando importa, con reporting claro y accionable.',
    deliverables: ['SEO técnico', 'Contenidos', 'Google Ads', 'Keyword research', 'Link building', 'Reporting'],
  },
];

const steps = [
  { num: 'P.01', title: 'Descubrimiento', desc: 'Entendemos tu negocio, audiencia y objetivos antes de tocar un pixel.' },
  { num: 'P.02', title: 'Estrategia', desc: 'Definimos el plan, los mensajes y los canales con métricas claras.' },
  { num: 'P.03', title: 'Diseño y build', desc: 'Creamos marca, web y piezas de campaña listas para lanzar.' },
  { num: 'P.04', title: 'Lanzar y optimizar', desc: 'Medimos, iteramos y escalamos lo que funciona.' },
];
---
<BaseLayout
  title="Servicios — Shape and Code"
  description="Branding, diseño web, marketing digital y SEO/SEM. Todo lo que tu marca necesita para crecer, bajo un mismo techo."
>

  <!-- HERO -->
  <section class="max-w-[1320px] mx-auto px-4 sm:px-6 md:px-8 pt-[120px] sm:pt-[150px] lg:pt-[180px] pb-10 sm:pb-14">
    <p data-reveal="up" class="font-space-mono text-[11px] sm:text-[12.5px] text-[#737373] dark:text-[#8a8a8a] tracking-[0.06em] mb-5 sm:mb-7">[ NUESTROS SERVICIOS ]</p>
    <h1 data-reveal="up" data-delay="1" class="font-bold leading-[0.94] tracking-[-0.035em] max-w-[14ch]" style="font-size: clamp(40px, 8.5vw, 132px)">
      Todo bajo un mismo techo.
    </h1>
    <div data-reveal="up" data-delay="2" class="mt-8 sm:mt-12 flex flex-col sm:flex-row flex-wrap gap-6 sm:gap-12 items-start sm:items-end justify-between">
      <p class="text-[#404040] dark:text-[#a3a3a3] leading-[1.5] max-w-[48ch]" style="font-size: clamp(16px, 1.5vw, 21px)">
        Cuatro áreas de trabajo que se combinan según lo que tu marca necesita. Diseño con estética y estrategia, siempre enfocado en resultados.
      </p>
      <a href="#contacto" class="inline-flex items-center gap-[10px] bg-[#0a0a0a] dark:bg-[#f5f5f5] text-[#fafafa] dark:text-[#111111] text-[14px] sm:text-[15px] font-semibold px-5 sm:px-[26px] py-[13px] sm:py-[15px] rounded-full hover:bg-[#2a2a2a] dark:hover:bg-[#d4d4d4] transition-colors shrink-0">
        Empezar un proyecto <span class="svc-arrow">↗</span>
      </a>
    </div>
  </section>

  <!-- SERVICIOS DETALLE -->
  <section id="servicios" class="max-w-[1320px] mx-auto px-4 sm:px-6 md:px-8 pt-14 sm:pt-[104px] pb-10">
    <div data-reveal="up" class="flex justify-between items-end flex-wrap gap-4 mb-[14px]">
      <h2 class="font-extrabold tracking-[-0.03em] leading-none" style="font-size: clamp(26px, 4vw, 56px)">Qué hacemos</h2>
      <p class="font-space-mono text-[11px] sm:text-[12.5px] text-[#737373] dark:text-[#8a8a8a] tracking-[0.04em]">[ 04 ÁREAS DE TRABAJO ]</p>
    </div>
    <div class="border-t border-[#0a0a0a] dark:border-[#f5f5f5]">
      {services.map((s, i) => (
        <div
          data-reveal="up" data-delay={i}
          class="svc-block group border-b border-[#e5e5e5] dark:border-[#2a2a2a] hover:bg-[#0a0a0a] dark:hover:bg-[#f5f5f5] hover:text-[#fafafa] dark:hover:text-[#111111] transition-colors duration-300 py-8 sm:py-12 px-1 sm:px-3"
        >
          <div class="svc-grid">
            <span class="svc-num font-space-mono text-[12px] sm:text-[13px] opacity-[0.55] pt-1">{s.num}</span>
            <div class="svc-head">
              <h3 class="font-bold tracking-[-0.02em] leading-[1.02]" style="font-size: clamp(24px, 3.4vw, 46px)">{s.title}</h3>
              <span class="svc-arrow">↗</span>
            </div>
            <div class="svc-body">
              <p class="text-[14px] sm:text-[16px] leading-[1.55] opacity-70 max-w-[52ch]">{s.desc}</p>
              <ul class="flex flex-wrap gap-[8px] sm:gap-[10px] mt-5 sm:mt-6">
                {s.deliverables.map((d) => (
                  <li class="svc-tag font-space-mono text-[11px] sm:text-[12px] tracking-[0.02em] px-3 py-[7px] rounded-full border border-[#d4d4d4] dark:border-[#3a3a3a] group-hover:border-[rgba(250,250,250,0.4)] dark:group-hover:border-[rgba(17,17,17,0.4)] transition-colors">
                    {d}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- PROCESO -->
  <section id="proceso" class="max-w-[1320px] mx-auto px-4 sm:px-6 md:px-8 py-14 sm:py-[84px]">
    <div data-reveal="up" class="flex justify-between items-end flex-wrap gap-4 mb-8 sm:mb-12">
      <h2 class="font-extrabold tracking-[-0.03em] leading-none max-w-[16ch]" style="font-size: clamp(26px, 4vw, 56px)">Un método claro, sin sorpresas</h2>
      <p class="font-space-mono text-[11px] sm:text-[12.5px] text-[#737373] dark:text-[#8a8a8a] tracking-[0.04em]">[ CÓMO TRABAJAMOS ]</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-[#e5e5e5] dark:bg-[#2a2a2a] border border-[#e5e5e5] dark:border-[#2a2a2a]">
      {steps.map((step, i) => (
        <div data-reveal="up" data-delay={i} class="bg-[#fafafa] dark:bg-[#1a1a1a] hover:bg-[#f0f0f0] dark:hover:bg-[#252525] transition-colors pt-7 sm:pt-8 px-5 sm:px-[26px] pb-8 sm:pb-10 min-h-[180px] sm:min-h-[220px] flex flex-col justify-between">
          <span class="font-space-mono text-[13px] text-[#737373] dark:text-[#8a8a8a]">{step.num}</span>
          <div>
            <h3 class="text-[18px] sm:text-[20px] font-bold tracking-[-0.01em] mb-[10px]">{step.title}</h3>
            <p class="text-[13.5px] sm:text-[14.5px] leading-[1.5] text-[#525252] dark:text-[#a3a3a3]">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section id="contacto" class="bg-[#0a0a0a] text-[#fafafa]">
    <div class="max-w-[1320px] mx-auto px-4 sm:px-6 md:px-8 py-16 sm:py-[112px]">
      <p data-reveal="up" class="font-space-mono text-[11px] sm:text-[12.5px] text-[#8a8a8a] tracking-[0.06em] mb-5 sm:mb-7">[ EMPECEMOS ]</p>
      <h2 data-reveal="up" data-delay="1" class="font-extrabold leading-[0.95] tracking-[-0.035em] max-w-[13ch]" style="font-size: clamp(34px, 8vw, 116px)">¿Cuál es tu próximo proyecto?</h2>
      <div data-reveal="up" data-delay="2" class="flex flex-col sm:flex-row flex-wrap gap-6 sm:gap-10 justify-between items-start sm:items-end mt-10 sm:mt-14">
        <a href="mailto:hola@shapeandcode.agency" class="font-semibold tracking-[-0.02em] border-b-2 border-[#8a8a8a] pb-[6px] hover:border-[#fafafa] transition-colors break-all" style="font-size: clamp(15px, 3vw, 38px)">
          hola@shapeandcode.agency
        </a>
        <a href="mailto:hola@shapeandcode.agency" class="inline-flex items-center gap-3 bg-[#fafafa] text-[#0a0a0a] text-[14px] sm:text-[16px] font-bold px-6 sm:px-8 py-4 sm:py-[18px] rounded-full hover:bg-[#d4d4d4] transition-colors shrink-0">
          Escribir un mensaje <span class="svc-arrow">↗</span>
        </a>
      </div>
    </div>
  </section>

  <style>
    /* ---- SERVICE BLOCKS ---- */
    .svc-grid {
      display: grid;
      grid-template-columns: 88px 1fr 1.2fr;
      gap: 0 40px;
      align-items: start;
    }
    .svc-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 20px;
    }

    /* Tablet & below: stack number above, head + body in one column */
    @media (max-width: 1023px) {
      .svc-grid {
        grid-template-columns: 48px 1fr;
        gap: 6px 16px;
        align-items: start;
      }
      .svc-head { grid-column: 2; }
      .svc-body { grid-column: 2; margin-top: 16px; }
    }

    @media (max-width: 479px) {
      .svc-grid {
        grid-template-columns: 1fr;
      }
      .svc-num { grid-column: 1; }
      .svc-head { grid-column: 1; margin-top: 4px; }
      .svc-body { grid-column: 1; margin-top: 14px; }
    }
  </style>

</BaseLayout>
