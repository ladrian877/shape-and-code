---
import BaseLayout from '../layouts/BaseLayout.astro';

const work = [
  { name: 'Proyecto Norte', tag: 'Branding + Web', year: '2026', desc: 'Identidad completa y sitio a medida para una marca de arquitectura.' },
  { name: 'Lumen Retail', tag: 'Campaña 360°', year: '2025', desc: 'Estrategia de paid media y contenido para el lanzamiento de tienda.' },
  { name: 'Cobalt Fintech', tag: 'UX/UI + SEO', year: '2025', desc: 'Rediseño de producto digital y posicionamiento orgánico.' },
  { name: 'Vela Estudio', tag: 'Identidad', year: '2024', desc: 'Naming, logotipo y sistema visual para un estudio creativo.' },
  { name: 'Mistral Foods', tag: 'Branding + Packaging', year: '2024', desc: 'Marca y empaque para una línea de productos gourmet.' },
  { name: 'Aurora Health', tag: 'Web + Campaña', year: '2023', desc: 'Sitio institucional y campaña de captación de pacientes.' },
];

const filters = ['Todos', 'Branding', 'Diseño web', 'Campañas', 'SEO / SEM'];
---
<BaseLayout
  title="Proyectos — Shape and Code"
  description="Trabajo seleccionado: branding, diseño web y campañas digitales para marcas que quieren crecer."
>

  <!-- HERO -->
  <section class="max-w-[1320px] mx-auto px-4 sm:px-6 md:px-8 pt-[120px] sm:pt-[150px] lg:pt-[180px] pb-10 sm:pb-14">
    <p data-reveal="up" class="font-space-mono text-[11px] sm:text-[12.5px] text-[#737373] dark:text-[#8a8a8a] tracking-[0.06em] mb-5 sm:mb-7">[ TRABAJO SELECCIONADO ]</p>
    <h1 data-reveal="up" data-delay="1" class="font-bold leading-[0.94] tracking-[-0.035em] max-w-[14ch]" style="font-size: clamp(40px, 8.5vw, 132px)">
      Proyectos que hablan por sí solos.
    </h1>
    <div data-reveal="up" data-delay="2" class="mt-8 sm:mt-12 flex flex-col sm:flex-row flex-wrap gap-6 sm:gap-12 items-start sm:items-end justify-between">
      <p class="text-[#404040] dark:text-[#a3a3a3] leading-[1.5] max-w-[48ch]" style="font-size: clamp(16px, 1.5vw, 21px)">
        Una selección del trabajo que hemos construido junto a marcas de distintos sectores. Estética y estrategia, siempre con resultados medibles.
      </p>
      <a href="/contacto" class="inline-flex items-center gap-[10px] bg-[#0a0a0a] dark:bg-[#f5f5f5] text-[#fafafa] dark:text-[#111111] text-[14px] sm:text-[15px] font-semibold px-5 sm:px-[26px] py-[13px] sm:py-[15px] rounded-full hover:bg-[#2a2a2a] dark:hover:bg-[#d4d4d4] transition-colors shrink-0">
        Empezar un proyecto <span class="svc-arrow">↗</span>
      </a>
    </div>
  </section>

  <!-- FILTROS -->
  <section class="max-w-[1320px] mx-auto px-4 sm:px-6 md:px-8 pb-8 sm:pb-10">
    <div data-reveal="up" class="flex flex-wrap gap-[8px] sm:gap-[10px] border-t border-[#e5e5e5] dark:border-[#2a2a2a] pt-6 sm:pt-8">
      {filters.map((f, i) => (
        <button
          class:list={[
            'filter-chip font-space-mono text-[11px] sm:text-[12px] tracking-[0.02em] px-4 py-[9px] rounded-full border transition-colors',
            i === 0
              ? 'bg-[#0a0a0a] dark:bg-[#f5f5f5] text-[#fafafa] dark:text-[#111111] border-[#0a0a0a] dark:border-[#f5f5f5]'
              : 'border-[#d4d4d4] dark:border-[#3a3a3a] hover:border-[#0a0a0a] dark:hover:border-[#f5f5f5]',
          ]}
        >
          {f}
        </button>
      ))}
    </div>
  </section>

  <!-- GRID DE PROYECTOS -->
  <section id="trabajo" class="max-w-[1320px] mx-auto px-4 sm:px-6 md:px-8 pb-14 sm:pb-[84px]">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-7">
      {work.map((project, i) => (
        <a data-reveal="up" data-delay={i % 2} href="/contacto" class="block group">
          <div class="work-placeholder relative aspect-[4/3] border border-[#e5e5e5] dark:border-[#2a2a2a] group-hover:border-[#0a0a0a] dark:group-hover:border-[#f5f5f5] transition-colors rounded-[4px] overflow-hidden">
            <span class="absolute left-4 bottom-[14px] font-space-mono text-[11px] text-[#9a9a9a] dark:text-[#6a6a6a] bg-[#fafafa] dark:bg-[#1a1a1a] px-2 py-1 rounded">
              imagen del proyecto
            </span>
          </div>
          <div class="flex justify-between items-start gap-4 mt-4 pb-[14px] border-b border-[#e5e5e5] dark:border-[#2a2a2a]">
            <div>
              <h3 class="text-[18px] sm:text-[21px] font-bold tracking-[-0.01em]">{project.name}</h3>
              <p class="text-[13px] sm:text-[14px] text-[#737373] dark:text-[#8a8a8a] mt-[3px]">{project.tag}</p>
              <p class="text-[13px] sm:text-[14px] text-[#525252] dark:text-[#a3a3a3] mt-[10px] max-w-[42ch] leading-[1.5]">{project.desc}</p>
            </div>
            <span class="font-space-mono text-[12px] sm:text-[13px] text-[#737373] dark:text-[#8a8a8a] shrink-0">{project.year}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section id="contacto" class="bg-[#0a0a0a] text-[#fafafa]">
    <div class="max-w-[1320px] mx-auto px-4 sm:px-6 md:px-8 py-16 sm:py-[112px]">
      <p data-reveal="up" class="font-space-mono text-[11px] sm:text-[12.5px] text-[#8a8a8a] tracking-[0.06em] mb-5 sm:mb-7">[ EMPECEMOS ]</p>
      <h2 data-reveal="up" data-delay="1" class="font-extrabold leading-[0.95] tracking-[-0.035em] max-w-[13ch]" style="font-size: clamp(34px, 8vw, 116px)">¿Sumamos tu marca a la lista?</h2>
      <div data-reveal="up" data-delay="2" class="flex flex-col sm:flex-row flex-wrap gap-6 sm:gap-10 justify-between items-start sm:items-end mt-10 sm:mt-14">
        <a href="mailto:hola@shapeandcode.agency" class="font-semibold tracking-[-0.02em] border-b-2 border-[#8a8a8a] pb-[6px] hover:border-[#fafafa] transition-colors break-all" style="font-size: clamp(15px, 3vw, 38px)">
          hola@shapeandcode.agency
        </a>
        <a href="/contacto" class="inline-flex items-center gap-3 bg-[#fafafa] text-[#0a0a0a] text-[14px] sm:text-[16px] font-bold px-6 sm:px-8 py-4 sm:py-[18px] rounded-full hover:bg-[#d4d4d4] transition-colors shrink-0">
          Hablemos <span class="svc-arrow">↗</span>
        </a>
      </div>
    </div>
  </section>

  <style>
    .work-placeholder {
      background-color: #f0f0f0;
      background-image: repeating-linear-gradient(135deg, #e8e8e8 0 2px, transparent 2px 11px);
    }
    :global(.dark) .work-placeholder {
      background-color: #1a1a1a;
      background-image: repeating-linear-gradient(135deg, #2a2a2a 0 2px, transparent 2px 11px);
    }
  </style>

</BaseLayout>
